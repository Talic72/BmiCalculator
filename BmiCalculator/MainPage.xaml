<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BmiCalculator.MainPage"
             Title="BMI Calculator">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="BMI Calculator"
                FontSize="28"
                HorizontalOptions="Center"
                FontAttributes="Bold"/>

            <!-- Gender Selection -->

            <Label
                Text="Select Gender"
                FontSize="20"
                HorizontalOptions="Center"/>

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="20">

                <Border x:Name="MaleBorder"
                        Stroke="Blue"
                        StrokeThickness="5"
                        Padding="15">

                    <VerticalStackLayout>
                        <Image
                            x:Name="MaleImage"
                            Source="blue_male_icon.png"
                            HeightRequest="120"
                            WidthRequest="120">

                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="MaleTapped"/>
                            </Image.GestureRecognizers>

                        </Image>

                        <Label
                            Text="Male"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Border>

                <Border x:Name="FemaleBorder"
                        Stroke="Gray"
                        StrokeThickness="5"
                        Padding="15">

                    <VerticalStackLayout>
                        <Image
                            x:Name="FemaleImage"
                            Source="pink_girl_icon.png"
                            HeightRequest="120"
                            WidthRequest="120">

                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="FemaleTapped"/>
                            </Image.GestureRecognizers>

                        </Image>

                        <Label
                            Text="Female"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Border>

            </HorizontalStackLayout>

            <!-- Height section -->

            <Label
                Text="Height (inches)"
                FontSize="18"/>

            <Slider
                x:Name="HeightSlider"
                Minimum="0"
                Maximum="100"
                Value="50"
                ValueChanged="HeightSlider_ValueChanged"/>

            <Label
                x:Name="HeightLabel"
                Text="50 inches"
                HorizontalOptions="Center"/>

            <!-- Weight section -->

            <Label
                Text="Weight (lbs)"
                FontSize="18"/>

            <Slider
                x:Name="WeightSlider"
                Minimum="0"
                Maximum="300"
                Value="90"
                ValueChanged="WeightSlider_ValueChanged"/>

            <Label
                x:Name="WeightLabel"
                Text="90 lbs"
                HorizontalOptions="Center"/>
        <!-- Calculate button-->
            <Button
                Text="Calculate BMI"
                Clicked="CalculateBMI_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>