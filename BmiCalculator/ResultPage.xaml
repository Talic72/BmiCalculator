<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BmiCalculator.ResultPage"
    Title="BMI Results">

    <VerticalStackLayout
        Padding="30"
        Spacing="20">

        <Label
            Text="BMI Results"
            FontSize="30"
            HorizontalOptions="Center" />

        <Label
            x:Name="BmiLabel"
            FontSize="24"
            HorizontalOptions="Center" />

        <Label
            x:Name="CategoryLabel"
            FontSize="22"
            HorizontalOptions="Center" />

        <Button
            Text="Health Recommendations"
            Clicked="Recommendations_Clicked" />

        <Button
            Text="Back To Input"
            Clicked="Back_Clicked" />

    </VerticalStackLayout>

</ContentPage>