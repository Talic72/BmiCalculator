<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BmiCalculator.RecommendationPage"
    Title="Recommendations">

    <VerticalStackLayout
        Padding="30"
        Spacing="20">

        <Label
            Text="Health Recommendations"
            FontSize="30"
            HorizontalOptions="Center"/>

        <Label
            x:Name="RecommendationLabel"
            FontSize="18"/>

        <Button
            Text="Back To Results"
            Clicked="BackResults_Clicked"/>

        <Button
            Text="Back To Input"
            Clicked="BackInput_Clicked"/>

    </VerticalStackLayout>

</ContentPage>